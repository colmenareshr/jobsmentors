# tao-run-deft-aoi — credentials template.
#
# Copy this file to <workspace>/.env and fill in values:
#   cp .env.example <workspace>/.env
#   # Edit <workspace>/.env and fill in values.
#
# The agent sources <workspace>/.env at the start of Pre-Flight.
# Variables already exported in your shell take precedence.

# === Container registry (NGC) ===
# A single NGC key gates every nvcr.io image this workflow pulls.
# The key needs read access to:
#   - nvcr.io/nvstaging/tao/*           (TAO Toolkit images:
#                                        tao-toolkit-pyt, tao-toolkit-deploy,
#                                        tao-toolkit-ds)
#   - nvcr.io/nv-metropolis-dev/*       (Metropolis SDG images:
#                                        metropolis-sdg/paidf-anomalygen,
#                                        used by the inline AnomalyGen stage)
# Get a key at https://ngc.nvidia.com → Setup → API Key.
export NGC_KEY=""

# === HuggingFace ===
# Required: Pre-Flight downloads model weights from HuggingFace on your
# behalf into augmentation/anomalygen/base_checkpoints/ (cached between
# runs; one-time ~22 GB for 2B SDG, ~140 GB if 14B + T5-11b is included).
# Also gates the PCB reference dataset auto-fetch.
# Models pulled:
#   - ChangeNet backbone     nvidia/C-RADIOv2-B
#   - SDG diffusion          nvidia/Cosmos-Predict2-2B-Text2Image (+ -14B-)
#   - Text encoder           google-t5/t5-large (or t5-11b)
#   - Eval embeddings        nvidia/C-RADIO-V3
#   - nn_score / mnn_score   facebook/dinov2-large
#   - AMP segmentation       facebook/sam2
#   - AMP captioning         Qwen/Qwen3-VL-4B-Instruct
#   - k-NN mining            google/siglip-base-patch16-224
#   - PCB dataset            nvidia/Cosmos-AnomalyGen-PCB-Dataset
# Get a token at https://huggingface.co/settings/tokens (read access is enough).
export HF_TOKEN=""
